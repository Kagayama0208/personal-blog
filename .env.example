# Database connection string (Postgres)
# Inside the devcontainer / docker-compose, the host is the "db" service:
DATABASE_URL=postgres://payload:payload@db:5432/payload
# For a local Postgres outside containers, use e.g.:
#DATABASE_URL=postgres://payload:payload@127.0.0.1:5432/payload

# Used to encrypt JWT tokens. Generate a strong value: `openssl rand -base64 32`
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash.
# 本番では必ず公開URLを設定する（未設定だと localhost にフォールバックする）。
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs. Generate: `openssl rand -base64 32`
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests. 本番では必須（未設定だとプレビュー認可がバイパスされる）。
PREVIEW_SECRET=YOUR_SECRET_HERE

# AWS S3 storage for media uploads.
# Leave S3_BUCKET empty to keep using the local filesystem (default for local dev).
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Only for S3-compatible storage (MinIO, Cloudflare R2, etc.). Leave empty for AWS S3.
S3_ENDPOINT=

# Plausible によるアクセス解析。PLAUSIBLE_DOMAIN を設定すると有効化（例: kousuke.dev）。
# 空のままなら計測しない（ローカル開発のデフォルト）。
PLAUSIBLE_DOMAIN=
# セルフホストの Plausible を使う場合のみ、スクリプトURLを指定（例: https://plausible.example.com/js/script.js）。
PLAUSIBLE_SRC=
